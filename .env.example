# Environment Configuration Template
# Copy this file to .env and fill with actual values

# ==================== Firebase Config ====================
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
REACT_APP_FIREBASE_PROJECT_ID=your_project_id_here
REACT_APP_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
REACT_APP_FIREBASE_APP_ID=your_app_id_here
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ==================== Cloudinary Config ====================
# Frontend (used for signed uploads)
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_here

# Backend (used for backend uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ==================== Backend Config ====================
PORT=5000
NODE_ENV=development

# Firebase Admin SDK (for backend authentication)
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_PRIVATE_KEY=your_private_key_here
FIREBASE_CLIENT_EMAIL=your_client_email_here

# ==================== Application Config ====================
# Loan defaults
REACT_APP_LOAN_DEFAULT_DAYS=14
REACT_APP_LOAN_DOCTOR_DAYS=21
REACT_APP_LOAN_MAX_RENEWALS=3

# Features
REACT_APP_ENABLE_CHATBASE=false
REACT_APP_ENABLE_ANALYTICS=true

# ==================== API Config ====================
REACT_APP_API_URL=http://localhost:5000
REACT_APP_TIMEOUT_MS=5000

# ==================== Security ====================
# CORS origins (backend)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Session
REACT_APP_SESSION_TIMEOUT_MS=3600000

# ==================== Monitoring ====================
# Sentry (optional - for error tracking)
REACT_APP_SENTRY_DSN=

# LogRocket (optional - for session replay)
REACT_APP_LOGROCKET_ID=

# ==================== Mail/Notifications ====================
# SendGrid (optional - for emails)
SENDGRID_API_KEY=

# Notes:
# 1. Never commit .env file to git (add to .gitignore)
# 2. REACT_APP_* variables are exposed to frontend
# 3. Backend variables should be kept secret (server-side only)
# 4. Firestore credentials should NOT be in .env (use serviceAccountKey.json)
